{
  "name": "Penguin",
  "colors": {
    "editor.background": "#1a1b26",
    "editor.foreground": "#e2e2e3",
    "activityBar.background": "#16161e",
    "sideBar.background": "#16161e",
    "statusBar.background": "#16161e",
    "statusBar.foreground": "#e2e2e3",
    "statusBar.debuggingBackground": "#16161e",
    "statusBar.debuggingForeground": "#e2e2e3",
    "statusBar.noFolderBackground": "#16161e",
    "statusBar.noFolderForeground": "#e2e2e3",
    "statusBarItem.remoteBackground": "#16161e",
    "statusBarItem.remoteForeground": "#e2e2e3",
    "titleBar.activeBackground": "#1a1b26",
    "titleBar.activeForeground": "#a9b1d6",
    "sideBarTitle.foreground": "#787c99",
    "activityBarBadge.background": "#ff9e64",
    "tab.activeBackground": "#1a1b26", // Background of the active tab
    "tab.inactiveBackground": "#1e1f2c", // Background of inactive tabs
    "tab.activeForeground": "#e2e2e3", // Text color of the active tab
    "tab.activeBorder": "#ff9e64", // Border at the bottom of the active tab
    "button.background": "#ff9e64",
    "button.foreground": "#1a1b26",
    "button.hoverBackground": "#ffb38a",
    "button.secondaryBackground": "#41a6b5",
    "button.secondaryForeground": "#1a1b26",
    "button.secondaryHoverBackground": "#5dbfcb",
    "gitDecoration.addedResourceForeground": "#41a6b5",
    "gitDecoration.modifiedResourceForeground": "#41a6b5",
    "gitDecoration.untrackedResourceForeground": "#41a6b5",
    "gitDecoration.renamedResourceForeground": "#41a6b5",
    "gitDecoration.submoduleResourceForeground": "#41a6b5",
    "gitDecoration.conflictingResourceForeground": "#ff9e64",
    "gitDecoration.deletedResourceForeground": "#c53b53",
    "scmGraph.foreground1": "#ff9e64",
    "scmGraph.foreground2": "#41a6b5",
    "scmGraph.foreground3": "#ffb38a",
    "scmGraph.foreground4": "#5dbfcb",
    "scmGraph.foreground5": "#e08952",
    "charts.orange": "#ff9e64",
    "charts.blue": "#41a6b5",
    "charts.red": "#f7768e",
    "charts.green": "#9ece6a",
    "charts.yellow": "#e0af68",
    "charts.purple": "#9d7cd8",
    "charts.lines": "#565f89"
  },
  "semanticHighlighting": true,
  "semanticTokenColors": {
		"enum": "#7aa2f7",
		"struct": "#41a6b5",
		"typeParameter": "#9d7cd8",
		"class": "#9d7cd8",
		"interface": "#ff9e64",
		"builtinType": "#ff9e64",
		"type": "#ff9e64",
		"macro": "#ff9e64",
		"modifier": "#ff0000",
		"function": "#7aa2f7",
		"method": "#7aa2f7",
		"*.async": "#7aa2f7",
		"*.mutable": "#7aa2f7"
	},
  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "fontStyle": "italic", "foreground": "#565f89" }
    },
    {
      "name": "Keyword, Storage",
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier.abstract",
        "keyword.control"
      ],
      "settings": { "foreground": "#9d7cd8" }
    },
    {
      "name": "Access Modifiers",
      "scope": ["storage.modifier"],
      "settings": { "foreground": "#ff9e64" }
    },
    {
      "name": "HTML Tags",
      "scope": ["entity.name.tag"],
      "settings": { "foreground": "#f7768e" }
    },
    {
      "name": "Functions and Methods",
      "scope": [
        "entity.name.function",
        "variable.function",
        "support.function"
      ],
      "settings": { "foreground": "#7aa2f7" }
    },
    {
      "name": "Types, Structs, Classes",
      "scope": [
        "entity.name.class",
        "support.class",
        "storage.type.primitive",
        "support.type",
        "entity.name.type"
      ],
      "settings": { "foreground": "#41a6b5" }
    },
    {
      "name": "Constants, Numbers, Tailwind Utility Classes, Attributes",
      "scope": [
        "constant",
        "constant.numeric",
        "support.constant",
        "entity.other.attribute-name",
        "entity.other.attribute-name.class"
      ],
      "settings": { "foreground": "#ff9e64" }
    },
    {
      "name": "Strings",
      "scope": ["string"],
      "settings": { "foreground": "#9ece6a" }
    },
    {
      "name": "Variables and Parameters",
      "scope": [
        "variable",
        "variable.parameter",
        "variable.other.readwrite",
        "variable.other.property",
        "variable.other.member",
        "variable.other.object",
        "variable.other.constant"
      ],
      "settings": { "foreground": "#e2e2e3" }
    },
    {
      "name": "Teal Punctuation and Namespaces",
      "scope": [
        "punctuation.separator.namespace",
        "entity.name.namespace",
        "storage.modifier.path",
        "storage.modifier.import",
        "entity.name.module"
      ],
      "settings": { "foreground": "#73daca" }
    },
    {
      "name": "Operators",
      "scope": ["keyword.operator", "punctuation"],
      "settings": { "foreground": "#89ddff" }
    },
    {
      "name": "Generic Type Arguments and Brackets",
      "scope": [
        "meta.type.parameters entity.name.type",
        "meta.type.parameters storage.type",
        "meta.type.parameters support.type",
        "meta.type.parameters storage.type.primitive",
        "meta.type.argument entity.name.type",
        "meta.type.argument storage.type",
        "meta.template.call entity.name.type",
        "meta.template.call storage.type",
        "meta.generic.type entity.name.type",
        "meta.generic.type storage.type",
        "punctuation.brackets.angle",
        "punctuation.definition.template-arguments",
        "meta.type.parameters punctuation.definition.parameters"
      ],
      "settings": { "foreground": "#6964ff" }
    }
  ]
}
